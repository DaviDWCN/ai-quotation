# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ai_quotation

# RabbitMQ
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# MinIO
MINIO_USER=admin
MINIO_PASSWORD=admin123

# IMAP
IMAP_HOST=localhost
IMAP_PORT=993
IMAP_USER=user@example.com
IMAP_PASSWORD=password
IMAP_USE_SSL=True
IMAP_MAILBOX=INBOX

# S3
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=admin
S3_SECRET_KEY=admin123
S3_REGION=us-east-1
S3_BUCKET=quotations

# Mail Polling
MAIL_POLL_INTERVAL=30
MAIL_MAX_ATTACHMENT_SIZE=10485760
