# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ai_quotation

# RabbitMQ
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# MinIO / S3
MINIO_USER=admin
MINIO_PASSWORD=admin123
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=admin
S3_SECRET_KEY=admin123
S3_REGION=us-east-1
S3_BUCKET=quotations

# Mail / IMAP
IMAP_HOST=localhost
IMAP_PORT=993
IMAP_USER=user@example.com
IMAP_PASSWORD=password
IMAP_USE_SSL=true
IMAP_MAILBOX=INBOX
MAIL_POLL_INTERVAL=30
MAIL_MAX_ATTACHMENT_SIZE=10485760

# Message Queue Topics
MQ_DEAD_LETTER_TOPIC=quotation.dead_letter
MQ_QUOTATION_PARSE_TOPIC=quotation.parse
